{
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/index.ts"
        },
        {
            "source": "/api-docs(.*)",
            "destination": "/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
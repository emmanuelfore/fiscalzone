{
  "version": "0.2.2",
  "defaults": {},
  "configurations": [
    {
      "name": "Debug Server (npm run dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "stopOnEntry": false,
      "autoAttachChildProcesses": true
    },
    {
      "name": "Debug Current File (TSX)",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Attach to Node (9229)",
      "type": "node",
      "request": "attach",
      "address": "localhost",
      "port": 9229,
      "restart": true,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": null
    }
  ]
}
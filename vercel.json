{
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/api-docs(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/((?!api|api-docs).*)",
            "destination": "/index.html"
        }
    ]
}
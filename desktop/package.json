{
  "name": "fisczim-pos",
  "version": "1.0.0",
  "description": "Standalone POS for Fiscal Stack",
  "author": "Fiscal Stack",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emmanuelfore/fisczim.git"
  },
  "build": {
    "appId": "com.fiscalstack.pos",
    "productName": "Fiscal Stack POS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "publish": [
        {
          "provider": "github",
          "owner": "emmanuelfore",
          "repo": "fisczim"
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  }
}
